generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  hubs            Hub[]
  channels        Channel[]
  posts           Post[]
  comments        Comment[]
  reactions       Reaction[]
  ciBoardEntries  CIBoardEntry[]
  permits         PermitToWork[]
  shiftHandovers  ShiftHandover[]
  notifications   Notification[]
  inviteCodes     InviteCode[]
  channelMembers  ChannelMember[]
}

model User {
  id        String   @id @default(uuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  phone     String   @unique
  email     String?  @unique
  role      String   @default("user") // admin, user
  name      String?
  status    String   @default("pending_org")
  adminAuthCode String? // One-time auth code for provisioned admins
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts          Post[]
  comments       Comment[]
  reactions      Reaction[]
  permits        PermitToWork[]
  shiftHandovers ShiftHandover[]
  notifications  Notification[]
  channelMembers ChannelMember[]
  inviteCodesCreated InviteCode[] @relation("InviteCodeCreator")
  inviteCodeId       String?
  invitedByCode      InviteCode?  @relation("InviteCodeUser", fields: [inviteCodeId], references: [id])
}

model Hub {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channels    Channel[]
}

model Channel {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  hubId       String?
  hub         Hub?     @relation(fields: [hubId], references: [id])
  name        String
  description String?
  category    String?
  accessType  String?
  eventTypes  Json     @default("[]") // Array of custom EventType objects {name, icon, color}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts   Post[]
  permits PermitToWork[]
  members ChannelMember[]
}

model Post {
  id               String          @id @default(uuid())
  tenantId         String
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  authorId         String
  author           User            @relation(fields: [authorId], references: [id])
  channelId        String?
  channel          Channel?        @relation(fields: [channelId], references: [id])
  subject          String?
  content          String
  eventType        String?
  mediaUrls        String[] // Array of URLs
  isPinned         Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  comments  Comment[]
  reactions Reaction[]
}

model Comment {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  mediaUrls String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reaction {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String // e.g., 'like', 'acknowledge'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CIBoardEntry {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  type      String // safety_cross, kaizen, problem_solving, checklist
  data      Json // Flexible schema for board data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PermitToWork {
  id               String         @id @default(uuid())
  tenantId         String
  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  requesterId      String
  requester        User           @relation(fields: [requesterId], references: [id])
  channelId        String
  channel          Channel        @relation(fields: [channelId], references: [id])
  status           String // requested, approved, expired
  expiresAt        DateTime
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model ShiftHandover {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  summary   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String   @unique
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model InviteCode {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  code        String    @unique
  createdById String
  createdBy   User      @relation("InviteCodeCreator", fields: [createdById], references: [id])
  usedBy      User[]    @relation("InviteCodeUser")
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

model ChannelMember {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String   @default("member") // member, admin
  joinedAt  DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([channelId, userId])
}

// Tombstone table — every hard-deleted record writes here so the sync engine
// can instruct clients to remove the record from their local SQLite database.
model DeletedRecord {
  id        String   @id @default(uuid())
  recordId  String   // The original ID of the deleted record
  tableName String   // WatermelonDB table name (e.g. 'channels', 'hubs', 'posts')
  tenantId  String
  deletedAt DateTime @default(now())

  @@index([tenantId, tableName, deletedAt])
}
