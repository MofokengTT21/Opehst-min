generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id             String          @id @default(uuid())
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  ciBoardEntries CIBoardEntry[]
  channels       Channel[]
  channelMembers ChannelMember[]
  comments       Comment[]
  hubs           Hub[]
  inviteCodes    InviteCode[]
  notifications  Notification[]
  permits        PermitToWork[]
  posts          Post[]
  reactions      Reaction[]
  shiftHandovers ShiftHandover[]
  users          User[]
}

model User {
  id                 String          @id @default(uuid())
  tenantId           String?
  phone              String          @unique
  email              String?         @unique
  role               String          @default("user")
  name               String?
  status             String          @default("pending_org")
  adminAuthCode      String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  inviteCodeId       String?
  channelMembers     ChannelMember[]
  comments           Comment[]
  inviteCodesCreated InviteCode[]    @relation("InviteCodeCreator")
  notifications      Notification[]
  permits            PermitToWork[]
  posts              Post[]
  reactions          Reaction[]
  shiftHandovers     ShiftHandover[]
  invitedByCode      InviteCode?     @relation("InviteCodeUser", fields: [inviteCodeId], references: [id])
  tenant             Tenant?         @relation(fields: [tenantId], references: [id])
}

model Hub {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  channels    Channel[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
}

model Channel {
  id          String          @id @default(uuid())
  tenantId    String
  hubId       String?
  name        String
  description String?
  category    String?
  accessType  String?
  eventTypes  Json            @default("[]")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  hub         Hub?            @relation(fields: [hubId], references: [id])
  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  members     ChannelMember[]
  permits     PermitToWork[]
  posts       Post[]
}

model Post {
  id        String     @id @default(uuid())
  tenantId  String
  authorId  String
  channelId String?
  subject   String?
  content   String
  eventType String?
  mediaUrls String[]
  isPinned  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  comments  Comment[]
  author    User       @relation(fields: [authorId], references: [id])
  channel   Channel?   @relation(fields: [channelId], references: [id])
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  reactions Reaction[]
}

model Comment {
  id        String   @id @default(uuid())
  tenantId  String
  postId    String
  authorId  String
  content   String
  mediaUrls String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Reaction {
  id        String   @id @default(uuid())
  tenantId  String
  postId    String
  userId    String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model CIBoardEntry {
  id        String   @id @default(uuid())
  tenantId  String
  type      String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model PermitToWork {
  id          String   @id @default(uuid())
  tenantId    String
  requesterId String
  channelId   String
  status      String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  channel     Channel  @relation(fields: [channelId], references: [id])
  requester   User     @relation(fields: [requesterId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model ShiftHandover {
  id        String   @id @default(uuid())
  tenantId  String
  authorId  String
  summary   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String   @unique
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model InviteCode {
  id          String    @id @default(uuid())
  tenantId    String
  code        String    @unique
  createdById String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  createdBy   User      @relation("InviteCodeCreator", fields: [createdById], references: [id])
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  usedBy      User[]    @relation("InviteCodeUser")
}

model ChannelMember {
  id        String   @id @default(uuid())
  tenantId  String
  channelId String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  channel   Channel  @relation(fields: [channelId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([channelId, userId])
}

model DeletedRecord {
  id        String   @id @default(uuid())
  recordId  String
  tableName String
  tenantId  String
  deletedAt DateTime @default(now())

  @@index([tenantId, tableName, deletedAt])
}
